# TrustShield Production Environment
# Copy this to .env.production on the server and fill in real values

# Database
DB_PASSWORD=trustshield-secure-prod-change-me

# Redis
REDIS_PASSWORD=trustshield-redis-prod-change-me

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars-change-me

# OIDC Configuration (Clerk or custom provider)
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
OIDC_ISSUER_URL=https://your-oidc-provider.com

# AWS S3 Configuration
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET=trustshield-assets-production
USE_S3_SIGV4=true

# Frontend URLs
NEXT_PUBLIC_API_URL=https://api.trustshield.local
NEXT_PUBLIC_OIDC_CLIENT_ID=your-oidc-client-id
NEXT_PUBLIC_OIDC_ISSUER_URL=https://your-oidc-provider.com

# Logging
LOG_LEVEL=info

# Feature Flags
SEED_DEMO_DATA=false
