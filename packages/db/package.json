{
  "name": "@trustshield/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --project tsconfig.json --outDir dist",
    "drizzle:generate": "drizzle-kit generate --config drizzle.config.ts",
    "drizzle:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "drizzle:check": "drizzle-kit check --config drizzle.config.ts",
    "drizzle:push": "drizzle-kit push --config drizzle.config.ts",
    "lint": "eslint src --ext .ts",
    "test": "../../node_modules/.pnpm/node_modules/.bin/tsx --test src/**/*.test.ts",
    "typecheck": "tsc --project tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "drizzle-orm": "^0.43.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
