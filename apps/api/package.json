{
  "name": "@trustshield/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --project tsconfig.json --outDir dist",
    "dev:nest": "tsx watch src/nest/main.ts",
    "openapi:generate": "(tsx src/nest/openapi.ts || test -f openapi.generated.json) && node scripts/augment-openapi.cjs",
    "start": "node dist/main.js",
    "start:nest": "node dist/nest/main.js",
    "lint": "eslint src --ext .ts",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --project tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@trustshield/core": "workspace:*",
    "@trustshield/db": "workspace:*",
    "@trustshield/validation": "workspace:*",
    "bullmq": "^5.71.1",
    "ioredis": "^5.10.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}
