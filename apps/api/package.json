{
  "name": "@trustshield/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/nest/main.ts",
    "build": "tsc --project tsconfig.json --outDir dist",
    "dev:nest": "tsx watch src/nest/main.ts",
    "openapi:generate": "(tsx src/nest/openapi.ts || test -f openapi.generated.json) && node scripts/augment-openapi.cjs",
    "start": "node dist/nest/main.js",
    "start:nest": "node dist/nest/main.js",
    "lint": "eslint src --ext .ts",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --project tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opentelemetry/instrumentation-express": "^0.54.0",
    "@opentelemetry/instrumentation-http": "^0.54.0",
    "@opentelemetry/instrumentation-pg": "^0.55.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@sentry/node": "^10.15.0",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.43.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "^8.1.0",
    "@trustshield/core": "workspace:*",
    "@trustshield/db": "workspace:*",
    "@trustshield/validation": "workspace:*",
    "bullmq": "^5.71.1",
    "ioredis": "^5.10.1",
    "minio": "^8.0.6",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}
