# TrustShield API – Environment Configuration (2026)

# ============================================================================
# LEAK CHECK APIS
# ============================================================================

# LeakCheck.io – Email/Username/Domain Leak Search
# Sign up: https://leakcheck.io/api
# Free: 200 requests/day, Trial: 10.000/day
LEAKCHECK_API_KEY=76d81752e9656ea124a08953dd3f45f3b804539a
LEAKCHECK_BASE_URL=https://leakcheck.io/api/v2

# Have I Been Pwned (HIBP)
# Sign up: https://haveibeenpwned.com/API/v3
# Free: Public API with rate limits
# Paid: €3.50/month for commercial use & higher limits
HIBP_API_KEY=your-hibp-api-key-here
HIBP_BASE_URL=https://haveibeenpwned.com/api/v3

# Pwned Passwords (HIBP) – Totally Free
# No API key needed – k-anonymity safe
# Link: https://api.pwnedpasswords.com/
PWNED_PASSWORDS_BASE_URL=https://api.pwnedpasswords.com

# Cybernews Data Leak Check (optional alternative)
# Sign up: https://cybernews.com/api/
# Free tier available
CYBERNEWS_API_KEY=your-cybernews-api-key-here

# ============================================================================
# IMAGE ANALYSIS APIS
# ============================================================================

# Google Cloud Vision API
# Sign up: https://cloud.google.com/vision/docs/quickstart
# Free: 1,000 requests/month
# Paid: $1.50-$6 per 1,000 images after free tier
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key-here
GOOGLE_CLOUD_PROJECT_ID=your-google-project-id

# AWS Rekognition (Image + Video)
# Sign up: https://aws.amazon.com/rekognition/
# Free Tier: 5,000 images/month for 12 months
# Then: $0.0006 per image
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-central-1

# Hugging Face Inference API – Totally Free
# Sign up: https://huggingface.co/settings/tokens
# Models: deepfake detection, nsfw detection, face detection
# Free: Fair usage policy (no hard limits)
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# Clarifai – Free Tier
# Sign up: https://clarifai.com/
# Free: 10,000 operations/month
# Paid: $10/month for 10,000 ops
CLARIFAI_API_KEY=your-clarifai-api-key-here
CLARIFAI_USER_ID=your-clarifai-user-id
CLARIFAI_APP_ID=your-clarifai-app-id

# SightEngine – Free Trial (50 reqs/month) + 30-day Trial (unlimited)
# Sign up: https://sightengine.com/
# Features: deepfake detection, NSFW, profanity, violence
# Pricing: $49-299/month after trial
SIGHTENGINE_USER_ID=your-sightengine-user-id
SIGHTENGINE_SECRET=your-sightengine-secret

# ============================================================================
# VIDEO ANALYSIS APIS
# ============================================================================

# AWS Rekognition Video (uses same AWS credentials above)
# Free Tier: 5,000 videos/month for 12 months
# Then: Depends on video length & operations

# OpenAI Vision API (new accounts get $5-18 credits)
# Sign up: https://platform.openai.com/
# Pricing: $0.01 per image after credits expire
OPENAI_API_KEY=your-openai-api-key-here

# ============================================================================
# REVERSE IMAGE SEARCH (Optional)
# ============================================================================

# TinEye MatchEngine
# Sign up: https://services.tineye.com/MatchEngine
# Trial available, pricing varies
TINEYE_API_KEY=your-tineye-api-key-here

# Lenso.ai
# Sign up: https://lenso.ai/api
# Free tier available
LENSO_API_KEY=your-lenso-api-key-here

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/Disable specific leak check services
FEATURE_LEAK_CHECK_ENABLED=true
FEATURE_IMAGE_ANALYSIS_ENABLED=true
FEATURE_VIDEO_ANALYSIS_ENABLED=false  # Not needed for MVP

# Which APIs to prioritize (comma-separated)
LEAK_CHECK_PROVIDERS=leakcheck,pwned-passwords,hibp
IMAGE_ANALYSIS_PROVIDERS=huggingface,google-cloud-vision
VIDEO_ANALYSIS_PROVIDERS=aws-rekognition

# ============================================================================
# RATE LIMITING & QUOTAS
# ============================================================================

# Rate limits per service (requests per minute)
LEAKCHECK_RATE_LIMIT=10
PWNED_PASSWORD_RATE_LIMIT=20
HIBP_RATE_LIMIT=5
GOOGLE_VISION_RATE_LIMIT=20

# Daily quotas for paid APIs
GOOGLE_VISION_DAILY_QUOTA=1000
AWS_REKOGNITION_DAILY_QUOTA=5000

# ============================================================================
# CACHE & PERFORMANCE
# ============================================================================

# Cache leak check results (24 hours)
LEAK_CHECK_CACHE_TTL=86400

# Cache image analysis results (7 days)
IMAGE_ANALYSIS_CACHE_TTL=604800

# Max upload size for images (in MB)
MAX_IMAGE_UPLOAD_SIZE=50

# Max upload size for videos (in MB)
MAX_VIDEO_UPLOAD_SIZE=500

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# API call logging
LOG_API_CALLS=true
LOG_API_LATENCY=true
LOG_API_ERRORS=true

# Sentry or similar error tracking
SENTRY_DSN=your-sentry-dsn-here

# ============================================================================
# DATA RETENTION & PRIVACY
# ============================================================================

# Delete uploaded images after X hours
IMAGE_RETENTION_HOURS=24

# Delete analysis results after X days
ANALYSIS_RESULT_RETENTION_DAYS=30

# GDPR: Allow users to request data deletion
GDPR_DATA_DELETION_ENABLED=true

# ============================================================================
# DEPLOYMENT
# ============================================================================

# Use these for production deployment
ENVIRONMENT=development  # development | staging | production
API_VERSION=v1
DEBUG=true  # Set to false in production
