# Syncfusion Essential Studio® License
# Get your key from: https://www.syncfusion.com/account/licenses
NEXT_PUBLIC_SYNCFUSION_LICENSE=your_syncfusion_license_key_here

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_API_TIMEOUT=30000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/trustshield_db

# Redis
REDIS_URL=redis://localhost:6379

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_BATCH_OPERATIONS=true
NEXT_PUBLIC_ENABLE_IMAGE_INDEXING=true

# Theme Configuration
NEXT_PUBLIC_THEME=light
# Options: light, dark, auto

# Pagination
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=20

# Image Search Configuration
NEXT_PUBLIC_MAX_BATCH_IMAGES=100
NEXT_PUBLIC_IMAGE_SIMILARITY_THRESHOLD=0.7
